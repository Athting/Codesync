# Server
PORT=5000

# Comma-separated list of allowed origins for API/Socket CORS.
# Use * only for quick local testing.
CLIENT_URLS=http://localhost:5173

# Code execution safeguards
EXECUTION_TIMEOUT_MS=8000
COMPILATION_TIMEOUT_MS=15000
MAX_CODE_LENGTH=100000
MAX_STDIN_LENGTH=20000
MAX_OUTPUT_BYTES=200000
MAX_CONCURRENT_EXECUTIONS=2

# API rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
EXECUTE_RATE_LIMIT_WINDOW_MS=60000
EXECUTE_RATE_LIMIT_MAX_REQUESTS=20

# Security (recommended for production)
# Keep false unless execution is sandboxed/containerized.
ALLOW_UNSANDBOXED_EXECUTION=false
# Optional: require this key in x-execute-api-key header for /api/execute.
EXECUTE_API_KEY=

# Frontend
# In production, keep this empty to auto-use the deployed origin.
VITE_SOCKET_URL=
